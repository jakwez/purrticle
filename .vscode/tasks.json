{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build debug",
      "type": "shell",
      "command": "cmake --build --preset debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Build release",
      "type": "shell",
      "command": "cmake --build --preset release",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "ctest --preset debug",
      "group": { "kind": "test", "isDefault": true },
      "dependsOn": "Build debug"
    },
    {
      "label": "Coverage report",
      "type": "shell",
      "command": "cmake --build --preset coverage && ctest --preset coverage && cmake --build --preset coverage --target coverage && open build/coverage/coverage_report/index.html",
      "group": "test"
    }
  ]
}
